						<param name="Value" range="0-1" type="num" unit="number"/>
						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>
						</param>
						<hint lang="pl" value="Ustawia wartość wyjścia (0-1)"/>
						<hint lang="en" value="Sets output value (0-1)"/>
						<hint lang="de" value="Bestimmt den Ausgangswert (0 - 1)"/>
                        <desc resKey="ledrgb_setvalue_1"/>
                    </method>
