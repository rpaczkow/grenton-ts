						<hint lang="pl" value="Maksymalna wartość jaka może przyjąć Value. Próba ustawienia wartości większej zwraca błąd"/>
						<hint lang="en" value="Maximum value which Value can adopt. Attempting to set a higher value will generate an error"/>
						<hint lang="de" value="öchstwert, der von Value angenommen werden kann. Ein höherer Wert generiert eine Fehlermeldung"/>
                        <desc resKey="ledrgb_maxvalue"/>
                    </feature>
					<feature default="0" get="true" index="9" name="MinValue" range="0-1" set="true" type="num" unit="number">
						<hint lang="pl" value="Minimalna wartość jaka może przyjąć Value. Próba ustawienia wartości mniejszej zwraca błąd"/>
						<hint lang="en" value="Minimum value which Value can adopt. Attempting to set a lower value will generate an error"/>
						<hint lang="de" value="Mindestwert, der von Value angenommen werden kann. Ein niedrigerer Wert generiert eine Fehlermeldung"/>
