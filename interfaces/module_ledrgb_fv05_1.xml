					<feature default="10000" get="true" index="10" name="RCorrection" range="0-10000" set="true" type="num" unit="number">
						<hint lang="pl" value="Korekcja bieli dla kanału R, domyślnie 10000"/>
						<hint lang="en" value="White correction - channel R (0-10,000), default 10,000"/>
						<hint lang="de" value="Weißkorrektur – R-Kanal (0 - 10000), Standardwert 10000"/>
                        <desc resKey="ledrgb_rcorrection"/>
                    </feature>
					<feature default="8333" get="true" index="11" name="GCorrection" range="0-10000" set="true" type="num" unit="number">
						<hint lang="pl" value="Korekcja bieli dla kanału G, domyślnie 8333"/>
						<hint lang="en" value="White correction - G channel (0-10,000), default 8,333"/>
						<hint lang="de" value="Weißkorrektur – G-Kanal (0 - 10000), Standardwert 8333"/>
                        <desc resKey="ledrgb_gcorrection"/>
                    </feature>
					<feature default="8333" get="true" index="12" name="BCorrection" range="0-10000" set="true" type="num" unit="number">
						<hint lang="pl" value="Korekcja bieli dla kanału B, domyślnie 8333"/>
						<hint lang="en" value="White correction - B channel (0-10,000), default 8,333"/>
						<hint lang="de" value="Weißkorrektur – B-Kanal (0 - 10000), Standardwert 8333"/>
                        <desc resKey="ledrgb_bcorrection"/>
                    </feature>
					<feature default="0" enum="0,1" get="true" index="13" name="StatisticState" previousValue="true" set="true" type="num" unit="number"  >
						<enum name="Off" resKey="ledrgb_statisticstate_enum_off" value="0"/>
						<enum name="Continuous" resKey="ledrgb_statisticstate_enum_continuous" value="1"/>
						<hint lang="pl" value="Włącza raportowanie pomiaru do modułu statystyk:&#13;Off - wyłączony,&#13;Continuous - pomiar obciążenia w całym okresie pracy urządzenia"/>
						<hint lang="en" value="Enables measurement reporting to the statistics module:&#13;Off - turned off,&#13;Continuous - load measurement for the whole device's period operation"/>
						<hint lang="de" value="Art der Messung: &#13;Off - ausgeschaltet, &#13;Continuous - Belastungsmessung während der gesamten Arbeitszeit des Geräts"/>
                        <desc resKey="ledrgb_statisticstate_1"/>
                    </feature>
					<feature correctValue="1" default="0" dependOn="13" get="true" index="14" name="Load" set="true" type="num" unit="W" range="0-60000" >
						<hint lang="pl" value="Mnożnik mierzonej wartości. Dla StatisticState:&#13;Continuous - wartość zużycia w jednostce czasu"/>
						<hint lang="en" value="The measured value multiplier. For StatisticState:&#13;Continuous - load measurement value in the unit of time"/>
						<hint lang="de" value="Messwertfaktor. Für StatisticState: &#13;Kontinuierlich - Verbrauch pro Zeiteinheit (z. B. 1 l, 1 m3, 1 kW)"/>
                        <desc resKey="ledrgb_load_1"/>
                    </feature>
				</features>
				<methods>
