						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>
						</param>
						<hint lang="pl" value="Ustawia wartość barwy (0-360)"/>
						<hint lang="en" value="Sets hue value (0-360)"/>
						<hint lang="de" value="Bestimmt den Farbwert (0 - 360)"/>
                        <desc resKey="ledrgb_sethue"/>
                    </method>
					<method call="execute" index="2" name="SetSaturation" return="void">
						<param name="Value" range="0-1" type="num" unit="number"/>
						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>
						</param>
						<hint lang="pl" value="Ustawia wartość nasycenia (0-1)"/>
						<hint lang="en" value="Sets saturation value (0-1)"/>
						<hint lang="de" value="Bestimmt den Sättigungswert (0 - 1)"/>
                        <desc resKey="ledrgb_setsaturation_1"/>
                    </method>
					<method call="execute" index="3" name="SetRvalue" return="void">
						<param name="Value" range="0-255" type="num" unit="number"/>
						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>
						</param>
						<hint lang="pl" value="Ustawia wartość składowej R(0-255) - kolor czerwony"/>
						<hint lang="en" value="Sets R component value (0-255)"/>
						<hint lang="de" value="Bestimmt die Komponente R (0 - 255)"/>
                        <desc resKey="ledrgb_setrvalue"/>
                    </method>
					<method call="execute" index="4" name="SetGvalue" return="void">
						<param name="Value" range="0-255" type="num" unit="number"/>
						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>
						</param>
						<hint lang="pl" value="Ustawia wartość składowej G(0-255) - kolor zielony"/>
						<hint lang="en" value="Sets G component value (0-255)"/>
						<hint lang="de" value="Bestimmt die Komponente G (0 - 255)"/>
                        <desc resKey="ledrgb_setgvalue"/>
                    </method>
					<method call="execute" index="5" name="SetBvalue" return="void">
						<param name="Value" range="0-255" type="num" unit="number"/>
						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>
						</param>
						<hint lang="pl" value="Ustawia wartość składowej B(0-255) - kolor niebieski"/>
						<hint lang="en" value="Sets B component value (0-255)"/>
						<hint lang="de" value="Bestimmt die Komponente B (0 - 255)"/>
                        <desc resKey="ledrgb_setbvalue"/>
                    </method>
					<method call="execute" index="6" name="SetRGBvalue" return="void">
						<param default="#ffffff" name="Value" range="" type="str" unit="HEX"/>
						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>
						</param>
						<hint lang="pl" value="Ustawia wartość RGB za pomocą ciągu znaków #RRGGBB"/>
						<hint lang="en" value="Sets RGB value using the #RRGGBB string"/>
						<hint lang="de" value="Bestimmt den RGB-Wert mit der Zeichenfolge „#RRGGBB”"/>
                        <desc resKey="ledrgb_setrgbvalue"/>
                    </method>
					<method call="execute" index="7" name="HoldValue" return="void">
						<param name="Ramp" optional="true" type="num" unit="ms"/>
						<hint lang="pl" value="Realizacja funkcji rozjaśniania/ściemniania"/>
						<hint lang="en" value="Executes illumination/ dimming function"/>
						<hint lang="de" value="Ausführung der Dimmfunktion (heller / dunkler)"/>
                        <desc resKey="ledrgb_holdvalue"/>
                    </method>
					<method call="execute" index="8" name="HoldHue" return="void">
						<param name="Ramp" optional="true" type="num" unit="ms"/>
						<hint lang="pl" value="Realizacja funkcji płynnej zmiany barwy"/>
						<hint lang="en" value="Executes smooth hue transition"/>
						<hint lang="de" value="Ausführung des stufenlosen Farbwechsels"/>
                        <desc resKey="ledrgb_holdhue"/>
                    </method>
					<method call="execute" index="9" name="SwitchOn" return="void">
						<param name="Time" type="num" unit="ms">
							<parametrized name="Unlimited" type="num" value="0"/>
							<parametrized name="Time"/>
						</param>
						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>						
						</param>
						<hint lang="pl" value="Ustawia wartość wyjścia na MaxValue"/>
						<hint lang="en" value="Sets output value to MaxValue"/>
						<hint lang="de" value="Setzt den Ausgangswert auf MaxValue"/>
                        <desc resKey="ledrgb_switchon"/>
                    </method>
					<method call="execute" index="10" name="SwitchOff" return="void">
						<param name="Time" type="num" unit="ms">
							<parametrized name="Unlimited" type="num" value="0"/>
							<parametrized name="Time"/>
						</param>
						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>
						</param>
						<hint lang="pl" value="Ustawia wartość wyjścia na MinValue"/>
						<hint lang="en" value="Sets output value to MinValue"/>
						<hint lang="de" value="Setzt den Ausgangswert auf MinValue"/>
                        <desc resKey="ledrgb_switchoff_1"/>
                    </method>
					<method call="execute" index="11" name="Switch" return="void">
						<param name="Time" type="num" unit="ms">
							<parametrized name="Unlimited" type="num" value="0"/>
							<parametrized name="Time"/>
						</param>
						<param name="Ramp" optional="true" range="0-15000" type="num" unit="ms">
							<parametrized name="Default" type="num" value=""/>
							<parametrized name="Time"/>
						</param>
						<hint lang="pl" value="Zmienia stan wyjścia na przeciwny. Pierwszy parametr to czas zmiany: 0 włącza wyjście na stałe, num na czas określony w parametrze. Drugi parametr to rampa jest opcjonalny, jeśli nie zostanie zdefiniowany przyjmowana jest wartość domyślna."/>
						<hint lang="en" value="Changes the output value from 0 to 1 or from 1 to 0. The first parameter is the time of change:&#13;0 - switches output to continuous mode spec&#13;number - switches output for a time specified by a parameter (in milliseconds)&#13;The second parameter is the ramp (time of value increments) which is optional. If this parameter is not specified, the default ramp is used"/>
						<hint lang="de" value="Wechselt den Ausgangswert von 0 auf 1 oder von 1 auf 0. Der erste Parameter ist die Wechselzeit: &#13;0 – schaltet den Ausgang für eine unbestimmte Zeit ein; &#13;num – schaltet den Ausgang für eine mit Parametern bestimmte Zeit (in Millisekunden) ein. Der zweite Parameter ist optional und es ist die Rampe (Anstiegszeit). Wird er nicht vorgegeben, nimmt er den Standardwert an."/>
                        <desc resKey="ledrgb_switch_1"/>
                    </method>
					<method call="set" index="7" name="SetRampTime" return="void">
						<param name="RampTime" type="num" unit="ms"/>
						<hint lang="pl" value="Ustawia czas narastania wartości barwy i jasności"/>
						<hint lang="en" value="Sets value of increment of colour and input (in ms)"/>
						<hint lang="de" value="Bestimmt die Rampenzeit des Farb- und Eingangswerts (ms)"/>
                        <desc resKey="ledrgb_setramptime"/>
                    </method>
					<method call="set" index="8" name="SetMax" return="void">
						<param name="Value" type="num"/>
						<hint lang="pl" value="Ustawia maksymalną wartość dla Value"/>
						<hint lang="en" value="Sets maximum value for Value"/>
						<hint lang="de" value="Bestimmt den Wert von MaxValue"/>
                        <desc resKey="ledrgb_setmax"/>
                    </method>
					<method call="set" index="9" name="SetMin" return="void">
						<param name="Value" type="num"/>
						<hint lang="pl" value="Ustawia minimalną wartość dla Value"/>
						<hint lang="en" value="Sets minimum value for Value"/>
						<hint lang="de" value="Bestimmt den Wert von MinValue"/>
                        <desc resKey="ledrgb_setmin"/>
                    </method>
				</methods>
				<events>
					<event address="0" name="OnChange">
						<hint lang="pl" value="Zdarzenie wywoływane przy zmianie stanu wyjścia"/>
						<hint lang="en" value="Event occurring when changing the output state"/>
						<hint lang="de" value="Ereignis bei Änderung des Ausgangsstatus"/>
                        <desc resKey="ledrgb_onchange"/>
                    </event>
					<event address="1" name="OnSwitchOn">
						<hint lang="pl" value="Zdarzenie wywoływane w momencie zmiany stanu wyjścia ze stanu=0 na stan&gt;0"/>
						<hint lang="en" value="Event occurring when the output state is changed from 0 to greater than 0"/>
						<hint lang="de" value="Wird aufgerufen, sobald der Ausgang vom Zustand = 0 auf Zustand &gt; 0 gewechselt ist"/>
                        <desc resKey="ledrgb_onswitchon_1"/>
                    </event>
					<event address="2" name="OnSwitchOff">
						<hint lang="pl" value="Zdarzenie wywoływane w momencie ustawienia 0 na wyjściu"/>
						<hint lang="en" value="Event occurring when 0 is set at the output"/>
						<hint lang="de" value="Wird aufgerufen, sobald der Ausgang auf „0” gesetzt worden ist"/>
                        <desc resKey="ledrgb_onswitchoff_1"/>
                    </event>
					<event address="3" name="OnRaiseValueSet"> 
						<hint lang="pl" value="Zdarzenie wywoływane przy zmianie wartości na wyższą (zbocze narastające)"/>
						<hint lang="en" value="Event occurring when the set value is higher than the current value"/>
						<hint lang="de" value="Wird aufgerufen, falls der eingestellte Wert höher ist als der aktuelle"/>
                        <desc resKey="ledrgb_onraisevalueset"/>
                    </event>
					<event address="4" name="OnLowerValueSet">
						<hint lang="pl" value="Zdarzenie wywoływane przy zmianie wartości na niższą (zbocze opadające)"/>
						<hint lang="en" value="Event occurring when the set value is lower than the current value"/>
						<hint lang="de" value="Wird aufgerufen, falls der eingestellte Wert niedriger ist als der aktuelle"/>
                        <desc resKey="ledrgb_onlowervalueset"/>
                    </event>
					<event address="5" name="OnOutOfRange">
						<hint lang="pl" value="Zdarzenie wywoływane w momencie ustawienia na wyjściu wartości spoza wyznaczonego zakresu (Min - Max)"/>
						<hint lang="en" value="Event occurring when setting  a value which is higher than the maximum value or lower than the minimum value"/>
						<hint lang="de" value="Wird aufgerufen, falls der eingestellte Wert höher als der Höchstwert oder niedriger als der Mindestwert ist"/>
                        <desc resKey="ledrgb_onoutofrange_1"/>
                    </event>
				</events>
			</interface>
		</object>
	</firmware>
</module>
