                    </feature>
					<feature get="true" index="5" name="BValue" range="0-255" set="false" type="num" unit="number">
						<hint lang="pl" value="Wartość składowej B(0-255) - kolor niebieski"/>
						<hint lang="en" value="B component value (0-255) - Blue"/>
						<hint lang="de" value="Komponentenwert G (0 - 255) – Grün"/>
                        <desc resKey="ledrgb_bvalue"/>
