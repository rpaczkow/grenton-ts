<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<module name="LEDRGBmodule" typeId="04">
	<!--hwType=0x4(4), hwVer=0x1(1), fwType=0x1(1), fwApiVer=0x5(5)-->
	<firmware typeId="01" version="05">
		<object class="9" count="1" name="LEDRGB" type="out">
			<interface>
				<features>
					<feature get="true" index="0" name="Value" range="0-1" set="false" type="num" unit="number">
						<hint lang="pl" value="Wartość jasności (zakres 0-1)"/>
						<hint lang="en" value="Brightness value (range: 0-1)"/>
