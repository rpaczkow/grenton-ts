					<feature get="true" index="4" name="GValue" range="0-255" set="false" type="num" unit="number">
						<hint lang="pl" value="Wartość składowej G(0-255) - kolor zielony"/>
						<hint lang="en" value="G component value (0-255) - Green"/>
						<hint lang="de" value="Komponentenwert B (0 - 255) – Blau"/>
                        <desc resKey="ledrgb_gvalue"/>
                    </feature>
					<feature get="true" index="6" name="RGB" range="" set="false" type="str" unit="HEX">
