				<methods>
					<method call="set" index="0" name="SetValue" return="void">
						<param name="Value" range="0-100" type="num" unit="%"/>
						<hint lang="pl" value="Ustawia wartość ściemniacza"/>
						<hint lang="en" value="Sets output value"/>
					    <desc resKey="zwave_dimmer_setvalue"/>
                    </method>
					<method call="set" index="1" name="SetMinValue" return="void">
						<param name="Value" range="0-100" type="num" unit="%"/>
						<hint lang="pl" value="Ustawia minimalną wartość ściemniacza"/>
						<hint lang="en" value="Setting the minimum value which can be adopted by an output. Attempting to set a lower value will generate an error"/>
					    <desc resKey="zwave_dimmer_setminvalue"/>
                    </method>
					<method call="set" index="2" name="SetMaxValue" return="void">
