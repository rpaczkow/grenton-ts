			<method call="execute" index="2" name="SetDateTime" return="void">
				<param name="UnixTimestamp" type="timestamp"/>
				<hint lang="pl" value="Ustawia datę i czas"/>
				<hint lang="en" value="Sets date and time"/>
				<hint lang="de" value="Stellt Datum und Zeit ein"/>
                <desc resKey="clu_setdatetime"/>
            </method>
			<method call="set" index="1" name="SetClientReportInterval" return="void">
				<param default="0" name="ClientReportInterval" range="1000-10000" type="num" unit="ms"/>
				<hint lang="pl" value="Ustawia okres raportowania o zmianach cech"/>
				<hint lang="en" value="Sets the characteristics change report period"/>
				<hint lang="de" value="Bestimmt die Zeitspanne, in der über Eigenschaftsänderungen berichtet wird"/>
                <desc resKey="clu_setclientreportinterval"/>
            </method>
			<method call="set" index="7" name="SetUpdateTime" range="1000-24000" return="void">
				<param name="Time" type="num" unit="ms"/>
				<hint lang="pl" value="Ustawia wartość parametru UpdateTime"/>
				<hint lang="en" value="Sets the Satel state update period - UpdateTime"/>
				<hint lang="de" value="Bestimmt das Zeitinterwall, in dem der Status der Zentraleinheit aktualisiert wird"/>
                <desc resKey="clu_setupdatetime"/>
            </method>
			<method call="set" index="2" name="SetSatelIP" return="void" unit="string">
				<param name="IP" type="num"/>
				<hint lang="pl" value="Ustawia adres IP modułu ETHM (Satel)"/>
				<hint lang="en" value="Sets the ETHM Satel module IP address"/>
				<hint lang="de" value="Definiert die IP-Adresse des ETHM-Moduls (Satel)"/>
                <desc resKey="clu_setsatelip"/>
            </method>
			<method call="set" index="3" name="SetSatelPort" return="void" unit="string">
				<param name="Port" type="num"/>
				<hint lang="pl" value="Ustawia port modułu ETHM (Satel)"/>
				<hint lang="en" value="Sets the ETHM Satel module port"/>
				<hint lang="de" value="Bestimmt den Port des ETHM-Moduls (Satel)"/>
                <desc resKey="clu_setsatelport"/>
            </method>
			<method call="set" index="5" name="SetAdminPassword" return="void" unit="string">
				<param name="Password" type="str"/>
				<hint lang="pl" value="Ustawia hasło Administratora"/>
				<hint lang="en" value="Sets the administrator password"/>
				<hint lang="de" value="Definiert das Administrator-Passwort"/>
                <desc resKey="clu_setadminpassword"/>
            </method>
			<method call="set" index="9" name="SetEncryptionEnabled" return="void" unit="bool">
				<param name="Enabled" type="num"/>
				<hint lang="pl" value="Załącza / wyłącza szyfrowanie"/>
				<hint lang="en" value="Enables or disables encrypting"/>
				<hint lang="de" value="Aktiviert/Deaktiviert die Verschlüsselung"/>
                <desc resKey="clu_setencryptionenabled"/>
            </method>
			<method call="set" index="8" name="SetEncryptionKey" return="void" unit="string">
				<param name="Key" type="str"/>
				<hint lang="pl" value="Ustawia klucz szyfrowania"/>
				<hint lang="en" value="Sets the Satel encrypting key"/>
				<hint lang="de" value="Bestimmt den Satel-Verschlüsselungskez"/>
                <desc resKey="clu_setencryptionkey"/>
            </method>
		</methods>
		<events>
			<event address="0" name="OnInit">
				<hint lang="pl" value="Zdarzenie wywoływane jednorazowo w momencie inicjalizacji urządzenia"/>
				<hint lang="en" value="Event occurring once during device initialization"/>
				<hint lang="de" value="Ereignis, das einmalig aufgerufen wird, sobald das Gerät aktiviert wird"/>
                <desc resKey="clu_oninit"/>
            </event>
		</events>
	</interface>
	<objects>
		<object maxInstances="-1" name="Zone" version="1"/>
		<object maxInstances="-1" name="Input" version="1"/>
		<object maxInstances="-1" name="Output" version="1"/>
	</objects>
	<modulesVersionConstraints>
	</modulesVersionConstraints>
